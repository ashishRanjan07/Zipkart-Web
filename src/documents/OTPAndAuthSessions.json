{
  "_schema_meta": {
    "primary_tables": ["otp_requests", "user_sessions", "admin_sessions", "refresh_tokens", "token_blacklist"],
    "description": "Manages all authentication flows — OTP issuance and verification, user/admin session lifecycle, refresh token rotation, and token revocation.",
    "primary_keys": {
      "otp_requests": "otp_id",
      "user_sessions": "session_id",
      "admin_sessions": "session_id",
      "refresh_tokens": "token_id",
      "token_blacklist": "blacklist_id"
    },
    "indexes": {
      "otp_requests": [
        "identifier (phone/email)",
        "otp_type",
        "status",
        "expires_at",
        "composite: (identifier, otp_type, status)"
      ],
      "user_sessions": [
        "user_id",
        "access_token_hash (UNIQUE)",
        "device_id",
        "status",
        "expires_at"
      ],
      "refresh_tokens": [
        "token_hash (UNIQUE)",
        "user_id",
        "is_revoked",
        "expires_at"
      ],
      "token_blacklist": [
        "token_jti (UNIQUE)",
        "expires_at (for TTL cleanup)"
      ]
    },
    "enums": {
      "otp_type": [
        "phone_login",
        "email_login",
        "phone_verification",
        "email_verification",
        "password_reset",
        "payment_confirmation",
        "wallet_withdrawal",
        "admin_mfa_backup",
        "change_phone",
        "change_email",
        "account_deletion"
      ],
      "otp_channel": ["sms", "email", "whatsapp", "voice_call"],
      "otp_status": ["pending", "verified", "expired", "max_attempts_exceeded", "invalidated"],
      "session_status": ["active", "expired", "revoked", "logged_out"],
      "token_revocation_reason": ["user_logout", "admin_force_logout", "session_expired", "password_changed", "account_suspended", "security_alert", "mfa_required"]
    },
    "constraints": [
      "Max 5 OTP requests per identifier per 15 minutes (rate limiting)",
      "Max 3 OTP verification attempts before status = max_attempts_exceeded",
      "OTP expires in 5 minutes (login), 10 minutes (other actions)",
      "Refresh token valid for 30 days, rotated on each use",
      "Access token TTL: 15 minutes (user app), 30 minutes (admin panel)"
    ],
    "security_notes": [
      "OTP values are NEVER stored in plaintext — only bcrypt hash is stored",
      "Access tokens are JWT (HS256/RS256); only the JTI is stored for blacklisting",
      "Refresh tokens stored as SHA256 hash only",
      "All tokens purged from blacklist after their natural expiry time (TTL cleanup)"
    ]
  },

