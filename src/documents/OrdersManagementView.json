        "customer_request",
        "item_out_of_stock",
        "store_capacity_full",
        "payment_failure",
        "delivery_address_unserviceable",
        "partner_not_available",
        "admin_cancelled",
        "fraud_detected",
        "customer_unreachable"
      ],
      "sla_status": ["within_sla", "at_risk", "breached"]
    },
    "constraints": [
      "order_display_id UNIQUE NOT NULL",
      "user_id FK -> users.user_id",
      "dark_store_id FK -> dark_stores.store_id",
      "delivery_partner_id FK -> delivery_partners.partner_id (nullable)",
      "coupon_id FK -> coupons.coupon_id (nullable)",
      "delivery_address_id FK -> user_addresses.address_id"
    ]
  },

