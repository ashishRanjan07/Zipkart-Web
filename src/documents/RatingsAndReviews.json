{
  "_schema_meta": {
    "primary_tables": ["product_reviews", "delivery_partner_reviews", "review_media", "review_helpfulness_votes", "review_moderation_logs"],
    "description": "Manages customer ratings and reviews for products and delivery partners, including moderation workflow, media attachments, and helpfulness voting.",
    "primary_keys": {
      "product_reviews": "review_id",
      "delivery_partner_reviews": "partner_review_id",
      "review_media": "media_id",
      "review_helpfulness_votes": "vote_id",
      "review_moderation_logs": "moderation_id"
    },
    "indexes": {
      "product_reviews": [
        "product_id",
        "user_id",
        "rating",
        "status",
        "is_verified_purchase",
        "created_at (DESC)",
        "composite: (user_id, order_item_id) UNIQUE"
      ],
      "delivery_partner_reviews": [
        "partner_id",
        "user_id",
        "order_id",
        "rating",
        "created_at (DESC)",
        "composite: (user_id, order_id) UNIQUE"
      ]
    },
    "enums": {
      "review_status": ["pending_moderation", "approved", "rejected", "flagged", "removed_by_user"],
      "rejection_reason": ["spam", "fake_review", "abusive_content", "competitor_mention", "irrelevant", "personal_info_shared", "duplicate"],
      "rating_source": ["post_delivery_prompt", "in_app_review", "email_link", "manual"],
      "helpfulness_vote": ["helpful", "not_helpful"]
    },
    "constraints": [
      "One product review per user per order_item_id (verified purchase constraint)",
      "One partner review per user per order_id",
      "Rating must be between 1.0 and 5.0",
      "Review text max 2000 characters",
      "Max 5 media attachments per review"
    ],
    "business_rules": [
      "Only users who ordered the product can leave a verified purchase review",
      "Unverified reviews allowed but marked separately",
      "Reviews auto-approved if positive sentiment (>= 4 stars) — negative goes to moderation queue",
      "Product avg_rating recalculated asynchronously after each new review",
      "Partner rating updated in real-time on each delivery"
    ]
  },

