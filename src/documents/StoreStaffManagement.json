{
  "_schema_meta": {
    "primary_tables": ["store_staff", "staff_shifts", "staff_attendance", "staff_tasks", "staff_performance_snapshots"],
    "description": "Manages all dark store staff — pickers, packers, ops leads — including roster scheduling, attendance tracking, task assignment, and performance metrics.",
    "primary_keys": {
      "store_staff": "staff_id",
      "staff_shifts": "shift_id",
      "staff_attendance": "attendance_id",
      "staff_tasks": "task_id",
      "staff_performance_snapshots": "snapshot_id"
    },
    "indexes": {
      "store_staff": ["employee_code (UNIQUE)", "dark_store_id", "role", "status", "is_active"],
      "staff_shifts": ["staff_id", "dark_store_id", "shift_date", "status"],
      "staff_attendance": ["staff_id", "attendance_date", "composite: (staff_id, attendance_date) UNIQUE"],
      "staff_tasks": ["assigned_to_staff_id", "order_id", "status", "created_at"]
    },
    "enums": {
      "staff_role": ["store_manager", "shift_supervisor", "senior_picker", "picker", "packer", "bike_rider_intern", "ops_executive", "security_guard", "housekeeping"],
      "staff_status": ["active", "on_leave", "suspended", "resigned", "terminated"],
      "shift_type": ["morning", "afternoon", "night", "split"],
      "attendance_status": ["present", "absent", "half_day", "late", "early_leave", "on_leave_approved", "on_leave_unapproved"],
      "task_type": ["pick_order", "pack_order", "stock_replenishment", "stock_count", "qc_check", "return_processing", "cleaning", "dispatch"],
      "task_status": ["pending", "in_progress", "completed", "skipped", "failed"],
      "leave_type": ["casual", "sick", "privilege", "compensatory", "unpaid"],
      "employment_type": ["full_time", "part_time", "contract", "on_demand_gig"]
    },
    "constraints": [
      "employee_code UNIQUE NOT NULL",
      "aadhaar_hash UNIQUE NOT NULL",
      "dark_store_id FK -> dark_stores.store_id",
      "One attendance record per staff per date"
    ]
  },

