{
  "_schema_meta": {
    "primary_tables": ["order_tracking_events", "partner_location_history", "delivery_otp_verifications", "delivery_photo_proofs", "delivery_attempts"],
    "description": "Powers real-time delivery tracking — partner GPS history, order status events visible to customers, OTP-based delivery confirmation, photo proof on delivery, and failed delivery attempt logging.",
    "primary_keys": {
      "order_tracking_events": "event_id",
      "partner_location_history": "location_id",
      "delivery_otp_verifications": "otp_verification_id",
      "delivery_photo_proofs": "proof_id",
      "delivery_attempts": "attempt_id"
    },
    "indexes": {
      "order_tracking_events": ["order_id", "event_type", "created_at (DESC)"],
      "partner_location_history": [
        "partner_id",
        "order_id",
        "recorded_at (DESC)",
        "composite: (partner_id, recorded_at) — used for live tracking"
      ],
      "delivery_attempts": ["order_id", "partner_id", "attempt_number"]
    },
    "enums": {
      "tracking_event_type": [
        "order_placed",
        "payment_confirmed",
        "store_accepted",
        "picking_started",
        "picking_completed",
        "packing_completed",
        "partner_assigned",
        "partner_reached_store",
        "order_picked_up",
        "out_for_delivery",
        "partner_nearby_500m",
        "delivery_attempted",
        "otp_verified",
        "delivered",
        "delivery_failed",
        "return_initiated",
        "cancelled"
      ],
      "delivery_failure_reason": [
        "customer_unreachable",
        "customer_refused",
        "wrong_address",
        "gate_closed",
        "customer_not_home",
        "cod_amount_unavailable",
        "safety_concern",
        "partner_emergency",
        "weather_conditions"
      ],
      "otp_verification_type": ["standard_4digit", "missed_call", "voice_otp"],
      "proof_type": ["photo_at_door", "signature", "self_signature_by_partner"]
    },
    "real_time_notes": [
      "partner_location_history uses time-series optimized storage (TimescaleDB or InfluxDB recommended)",
      "Location points collected every 10 seconds while partner is on delivery",
      "Customer tracking URL is shareable and expires after order delivery + 2 hours",
      "Nearby alert (500m) triggered via geofence check in real-time",
      "OTP is 4 digits, valid for 10 minutes after partner marks 'arrived'"
    ]
  },

