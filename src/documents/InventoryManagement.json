{
  "_schema_meta": {
    "primary_table": "inventory",
    "related_tables": [
      "inventory_batches",
      "inventory_locations",
      "stock_movements",
      "purchase_orders",
      "purchase_order_items",
      "inventory_damage_log"
    ],
    "primary_key": "inventory_id",
    "indexes": [
      "composite: (dark_store_id, product_id, variant_id) UNIQUE",
      "dark_store_id",
      "product_id",
      "variant_id",
      "sku",
      "status",
      "quantity_available",
      "reorder_point",
      "last_updated_at"
    ],
    "enums": {
      "inventory_status": ["in_stock", "low_stock", "out_of_stock", "unserviceable", "hold_qc", "expiring_soon", "expired"],
      "stock_movement_type": [
        "purchase_receipt",
        "sale_deduction",
        "manual_adjustment_add",
        "manual_adjustment_remove",
        "damage_write_off",
        "expiry_write_off",
        "inter_store_transfer_out",
        "inter_store_transfer_in",
        "return_from_customer",
        "return_to_supplier",
        "qc_hold",
        "qc_release"
      ],
      "purchase_order_status": ["draft", "sent_to_supplier", "confirmed", "partially_received", "received", "cancelled"],
      "adjustment_reason": [
        "stock_count_correction",
        "damage",
        "expiry",
        "theft",
        "supplier_short_delivery",
        "system_error_correction",
        "inter_store_transfer",
        "return_from_customer",
        "promotional_sample"
      ],
      "storage_zone": ["ambient", "refrigerated_0_4C", "refrigerated_4_8C", "frozen_minus_18C", "frozen_minus_25C"]
    },
    "constraints": [
      "composite (dark_store_id, variant_id) UNIQUE",
      "dark_store_id FK -> dark_stores.store_id",
      "product_id FK -> products.product_id",
      "variant_id FK -> product_variants.variant_id"
    ]
  },

