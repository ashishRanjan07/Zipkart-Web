  "ab_test_experiments": [
    {
      "experiment_id": "exp_checkout_upsell_v2",
      "name": "Checkout Upsell Widget V2",
      "hypothesis": "Showing frequently-bought-together items at checkout will increase AOV by 8%.",
      "status": "running",
      "rollout_strategy": "percentage_random",
      "rollout_pct": 50,
      "platforms": ["android", "ios"],
      "variants": [
        {
          "variant_id": "ctrl",
          "name": "Control",
          "description": "No upsell widget at checkout",
          "traffic_pct": 50
        },
        {
          "variant_id": "var_a",
          "name": "Frequently Bought Together",
          "description": "Show 3 frequently-bought-together products at checkout",
          "traffic_pct": 50
        }
      ],
      "primary_metric": "avg_order_value",
      "secondary_metrics": ["conversion_rate", "items_per_order"],
      "min_sample_size": 10000,
      "current_sample_size": 8420,
      "start_at": "2026-06-01T00:00:00.000Z",
      "end_at": "2026-06-30T23:59:59.000Z",
      "results": {
        "control_aov": 320.25,
        "variant_a_aov": 341.80,
        "lift_pct": 6.73,
        "is_statistically_significant": false,
        "p_value": 0.08,
        "confidence_pct": 92
      },
      "created_by": "adm_9f8a7b6c",
      "created_at": "2026-05-28T10:00:00.000Z"
    }
  ]
