{
  "_schema_meta": {
    "primary_tables": ["app_configs", "feature_flags", "app_config_audit_log", "maintenance_windows", "force_update_configs", "ab_test_experiments"],
    "description": "Remote configuration system for the Zipkart platform. Controls app behavior without code deploys — feature flags, A/B experiments, maintenance windows, force-update rules, and all key-value config params.",
    "primary_keys": {
      "app_configs": "config_id",
      "feature_flags": "flag_id",
      "maintenance_windows": "maintenance_id",
      "force_update_configs": "update_rule_id",
      "ab_test_experiments": "experiment_id"
    },
    "indexes": {
      "app_configs": ["config_key (UNIQUE)", "category", "is_active"],
      "feature_flags": ["flag_key (UNIQUE)", "status", "rollout_pct"],
      "ab_test_experiments": ["status", "start_at", "end_at"]
    },
    "enums": {
      "config_data_type": ["string", "integer", "float", "boolean", "json", "csv_list"],
      "config_category": ["delivery", "payments", "catalog", "notifications", "users", "partners", "promotions", "system", "search", "loyalty"],
      "config_environment": ["production", "staging", "development"],
      "feature_flag_status": ["enabled", "disabled", "rollout", "sunset"],
      "rollout_strategy": ["all_users", "percentage_random", "user_id_list", "user_segment", "dark_store_ids", "platform"],
      "experiment_status": ["draft", "running", "paused", "concluded", "archived"],
      "maintenance_type": ["full_maintenance", "partial_maintenance", "read_only_mode", "partner_app_only"],
      "force_update_type": ["mandatory", "recommended"]
    }
  },

