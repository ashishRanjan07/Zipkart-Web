{
  "_schema_meta": {
    "primary_table": "notification_campaigns",
    "related_tables": [
      "notification_templates",
      "notification_delivery_logs",
      "notification_analytics",
      "notification_opt_outs",
      "notification_ab_tests"
    ],
    "primary_key": "campaign_id",
    "indexes": [
      "status",
      "campaign_type",
      "channel",
      "send_at",
      "created_by",
      "is_deleted",
      "composite: (status, send_at)"
    ],
    "enums": {
      "campaign_type": ["transactional", "promotional", "operational", "re_engagement", "flash_sale_alert", "order_update", "payment_update", "security_alert"],
      "channel": ["push", "sms", "email", "in_app", "whatsapp"],
      "status": ["draft", "scheduled", "sending", "sent", "paused", "cancelled", "failed"],
      "delivery_status": ["pending", "sent", "delivered", "opened", "clicked", "converted", "failed", "bounced", "opted_out"],
      "segment": ["all_users", "active_last_7_days", "active_last_30_days", "inactive_30days", "inactive_60days", "new_users_last_7_days", "high_value", "gold_tier", "platinum_tier", "cart_abandoned", "specific_users"],
      "template_type": ["push", "sms", "email_html", "email_text", "in_app_banner", "in_app_modal", "whatsapp"]
    },
    "constraints": [
      "send_at > created_at (for scheduled campaigns)",
      "target_audience.total_target_users >= 0"
    ]
  },

