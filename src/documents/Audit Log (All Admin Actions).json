      "entity_type": [
        "order", "order_item", "user", "admin_user", "delivery_partner",
        "dark_store", "product", "category", "brand", "inventory_item", "inventory_batch",
        "payment_transaction", "refund", "settlement", "coupon", "flash_sale",
        "notification_campaign", "notification_template", "role", "system_config", "session",
        "purchase_order", "partner_payout"
      ],
      "severity": ["low", "medium", "high", "critical"],
      "module": [
        "orders", "inventory", "catalog", "users", "delivery_partners",
        "dark_stores", "payments", "coupons", "flash_sales", "notifications",
        "reports", "system", "auth", "analytics"
      ]
    },
    "retention_policy": {
      "default_retention_days": 365,
      "sensitive_actions_retention_days": 1825,
      "legal_hold_indefinite": true,
      "notes": "Audit logs are immutable. No UPDATE or DELETE allowed. Archived to cold storage after retention period."
    }
