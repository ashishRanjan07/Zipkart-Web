        "notification_campaign_cancelled", "notification_template_updated",
        "dark_store_created", "dark_store_updated", "dark_store_shutdown",
        "dark_store_manager_assigned", "dark_store_pincodes_updated",
        "admin_created", "admin_updated", "admin_suspended", "admin_deleted",
        "admin_role_changed", "admin_permissions_updated", "admin_ip_whitelist_updated",
        "admin_password_reset", "admin_mfa_reset",
        "admin_session_revoked",
        "system_maintenance_mode_enabled", "system_maintenance_mode_disabled",
        "system_app_config_updated", "system_role_created", "system_role_updated",
        "report_exported", "report_scheduled",
