{
  "_schema_meta": {
    "primary_tables": ["delivery_zones", "zone_dark_store_assignments", "pincode_serviceability", "geofences", "delivery_zone_restrictions"],
    "description": "Defines geographic delivery zones, maps them to dark stores, controls pincode-level serviceability, and stores geofence polygon boundaries for real-time location checks.",
    "primary_keys": {
      "delivery_zones": "zone_id",
      "pincode_serviceability": "serviceability_id",
      "geofences": "geofence_id"
    },
    "indexes": {
      "delivery_zones": ["zone_code (UNIQUE)", "city", "status"],
      "pincode_serviceability": [
        "pincode (UNIQUE within dark_store)",
        "dark_store_id",
        "is_serviceable",
        "composite: (pincode, dark_store_id) UNIQUE"
      ],
      "geofences": ["dark_store_id (UNIQUE)", "geofence_type"]
    },
    "enums": {
      "zone_status": ["active", "inactive", "under_expansion", "sunset"],
      "serviceability_status": ["serviceable", "temporarily_unavailable", "unserviceable", "coming_soon"],
      "geofence_type": ["delivery_zone", "no_go_zone", "restricted_zone", "dark_store_boundary"],
      "restriction_type": ["alcohol_not_allowed", "tobacco_not_allowed", "cod_not_allowed", "prescription_not_allowed"]
    },
    "spatial_notes": [
      "Geofence boundaries stored as GeoJSON Polygon coordinates (WGS84)",
      "PostGIS extension recommended for spatial queries",
      "Pincode centroid coordinates stored for distance calculations",
      "Delivery radius checked against geofence polygon for precise boundary enforcement"
    ]
  },

