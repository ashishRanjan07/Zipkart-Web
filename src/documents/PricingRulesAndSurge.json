{
  "_schema_meta": {
    "primary_tables": ["pricing_rules", "delivery_fee_configs", "surge_configs", "surge_events", "dynamic_pricing_logs"],
    "description": "Controls all pricing logic — delivery fee tiers by order value and distance, surge pricing activation during peak demand, rule-based dynamic pricing adjustments, and an immutable audit log of all price changes applied at checkout.",
    "primary_keys": {
      "pricing_rules": "rule_id",
      "delivery_fee_configs": "fee_config_id",
      "surge_configs": "surge_config_id",
      "surge_events": "surge_event_id",
      "dynamic_pricing_logs": "log_id"
    },
    "indexes": {
      "pricing_rules": ["rule_type", "is_active", "priority", "valid_from", "valid_to"],
      "surge_events": ["dark_store_id", "zone_id", "is_active", "triggered_at"],
      "dynamic_pricing_logs": ["order_id", "product_id", "dark_store_id", "created_at"]
    },
    "enums": {
      "rule_type": ["delivery_fee", "product_price_markup", "product_price_discount", "surge_multiplier", "packaging_fee", "tip_config"],
      "fee_basis": ["order_value", "distance_km", "flat", "percentage"],
      "surge_trigger": ["manual", "auto_high_demand", "auto_low_supply", "auto_peak_hour", "weather_event", "festival"],
      "surge_status": ["monitoring", "warning", "active", "critical"],
      "pricing_rule_scope": ["global", "city", "zone", "dark_store", "pincode", "user_segment", "platform"]
    },
    "business_rules": [
      "Delivery fee = base_fee + distance_component + packaging_fee - free_delivery_discount",
      "Surge multiplier applies on delivery fee only, NOT on product prices",
      "Gold/Platinum/VIP tier users and Plus subscribers are exempt from surge fees",
      "Free delivery threshold checked AFTER discounts are applied",
      "Pricing rules evaluated in priority order; first matching rule wins"
    ]
  },

