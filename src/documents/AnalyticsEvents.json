{
  "_schema_meta": {
    "primary_tables": ["user_events", "funnel_events", "daily_store_metrics", "hourly_metrics_snapshots", "product_impression_logs"],
    "description": "Captures all user behavioral events (app telemetry), conversion funnel tracking, and aggregated operational metrics for dashboards, ML model training, and business reporting.",
    "primary_keys": {
      "user_events": "event_id",
      "funnel_events": "funnel_event_id",
      "daily_store_metrics": "metric_id",
      "hourly_metrics_snapshots": "snapshot_id",
      "product_impression_logs": "impression_id"
    },
    "indexes": {
      "user_events": [
        "user_id",
        "event_type",
        "dark_store_id",
        "created_at (DESC)",
        "session_id",
        "composite: (user_id, event_type, created_at) — user funnel analysis",
        "composite: (event_type, created_at) — platform-wide event aggregation"
      ],
      "funnel_events": ["funnel_name", "user_id", "step", "session_id", "created_at"],
      "daily_store_metrics": ["dark_store_id", "metric_date (UNIQUE per store)", "city"],
      "hourly_metrics_snapshots": ["dark_store_id", "snapshot_hour (DESC)", "composite: (dark_store_id, snapshot_hour) UNIQUE"],
      "product_impression_logs": ["product_id", "dark_store_id", "user_id", "placement", "created_at (DESC)"]
    },
    "enums": {
      "event_type": [
        "app_open", "app_background", "app_foreground", "app_crash",
        "screen_view", "scroll",
        "search_query", "search_result_click", "search_filter_applied", "search_sort_applied", "search_zero_results",
        "category_browse", "subcategory_browse",
        "product_view", "product_image_swipe", "product_variant_select", "product_share",
        "add_to_cart", "remove_from_cart", "cart_view", "cart_coupon_apply", "cart_coupon_remove",
        "checkout_start", "checkout_address_select", "checkout_payment_method_select", "checkout_place_order",
        "order_placed", "order_cancelled",
        "wishlist_add", "wishlist_remove",
        "notification_received", "notification_opened", "notification_dismissed",
        "banner_impression", "banner_click",
        "flash_sale_view", "flash_sale_product_click",
        "referral_link_share", "referral_signup_complete",
        "wallet_topup_start", "wallet_topup_complete",
        "loyalty_points_view", "subscription_view", "subscription_purchase",
        "review_submit", "rating_submit",
        "support_ticket_open", "support_faq_view", "support_chat_start",
        "account_created", "login_success", "logout",
        "permission_granted", "permission_denied",
        "deep_link_open"
      ],
      "event_source": ["android_app", "ios_app", "web_app", "pwa", "admin_portal", "partner_app"],
      "funnel_name": ["registration", "order_placement", "subscription_purchase", "wallet_topup", "referral_onboarding"],
      "funnel_step_status": ["entered", "completed", "dropped"]
    },
    "storage_notes": [
      "user_events is a very high-volume table — partition by date (daily or weekly) in production",
      "Consider Apache Kafka + Flink for real-time event streaming before writing to PostgreSQL or ClickHouse",
      "ClickHouse or BigQuery recommended for analytics queries on user_events (OLAP workload)",
      "product_impression_logs powers search ranking signals — feed into ML pipeline nightly",
      "hourly_metrics_snapshots retained for 90 days; daily_store_metrics retained indefinitely",
      "No PII in product_impression_logs — user_id only, no name/phone/email"
    ]
  },

