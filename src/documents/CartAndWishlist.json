{
  "_schema_meta": {
    "primary_tables": ["carts", "cart_items", "wishlists", "wishlist_items", "saved_for_later"],
    "description": "Manages the active shopping cart, saved wishlists, and 'saved for later' items for each user. One active cart per user per delivery address context.",
    "primary_keys": {
      "carts": "cart_id",
      "cart_items": "cart_item_id",
      "wishlists": "wishlist_id",
      "wishlist_items": "wishlist_item_id",
      "saved_for_later": "saved_item_id"
    },
    "indexes": {
      "carts": [
        "user_id (UNIQUE active cart per user)",
        "status",
        "dark_store_id",
        "expires_at",
        "updated_at"
      ],
      "cart_items": [
        "cart_id",
        "product_id",
        "variant_id",
        "composite: (cart_id, variant_id) UNIQUE"
      ],
      "wishlists": [
        "user_id",
        "is_default"
      ],
      "wishlist_items": [
        "wishlist_id",
        "product_id",
        "composite: (wishlist_id, variant_id) UNIQUE"
      ]
    },
    "enums": {
      "cart_status": ["active", "abandoned", "converted_to_order", "expired", "merged"],
      "cart_item_availability": ["available", "out_of_stock", "price_changed", "removed_from_catalog", "quantity_reduced"],
      "saved_for_later_status": ["available", "out_of_stock", "price_changed"]
    },
    "constraints": [
      "One active cart per user_id (status = active) — enforced via unique partial index",
      "cart_id FK -> carts.cart_id",
      "user_id FK -> users.user_id",
      "dark_store_id FK -> dark_stores.store_id",
      "variant_id FK -> product_variants.variant_id",
      "wishlist_id FK -> wishlists.wishlist_id"
    ],
    "business_rules": [
      "Cart is locked to a dark_store_id determined by user's selected delivery address",
      "If dark store changes, cart items are re-validated for availability",
      "Cart auto-expires after 7 days of inactivity",
      "Max 50 unique items per cart",
      "Price snapshot is taken at add-to-cart time; stale prices are flagged on checkout"
    ]
  },

