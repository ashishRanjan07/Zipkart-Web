{
  "_schema_meta": {
    "primary_tables": ["suppliers", "supplier_contacts", "supplier_products", "supplier_pricing_agreements", "supplier_contracts"],
    "description": "Manages supplier/vendor master data, product catalogs supplied, negotiated pricing agreements, and procurement contracts. Used by the inventory and purchase order system.",
    "primary_keys": {
      "suppliers": "supplier_id",
      "supplier_contacts": "contact_id",
      "supplier_products": "supplier_product_id",
      "supplier_pricing_agreements": "agreement_id",
      "supplier_contracts": "contract_id"
    },
    "indexes": {
      "suppliers": ["gstin (UNIQUE)", "pan (UNIQUE)", "status", "city", "is_approved"],
      "supplier_products": [
        "supplier_id",
        "product_id",
        "variant_id",
        "is_active",
        "composite: (supplier_id, variant_id) UNIQUE"
      ],
      "supplier_pricing_agreements": [
        "supplier_id",
        "dark_store_id",
        "is_active",
        "valid_to"
      ]
    },
    "enums": {
      "supplier_type": ["manufacturer", "distributor", "wholesaler", "local_vendor", "importer", "farmer_cooperative"],
      "supplier_status": ["pending_approval", "active", "suspended", "blacklisted", "inactive"],
      "payment_terms": ["immediate", "net_7", "net_15", "net_30", "net_45", "net_60", "advance"],
      "delivery_mode": ["self_delivery", "third_party_logistics", "pickup_by_us"],
      "agreement_status": ["draft", "active", "expired", "terminated"],
      "contract_type": ["annual_supply", "spot_purchase", "consignment", "exclusive_supply"]
    },
    "constraints": [
      "gstin UNIQUE NOT NULL",
      "pan UNIQUE NOT NULL",
      "At least one contact required per supplier",
      "Pricing agreement: cost_price >= 0"
    ]
  },

