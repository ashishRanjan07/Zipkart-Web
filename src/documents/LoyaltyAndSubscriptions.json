{
  "_schema_meta": {
    "primary_tables": ["loyalty_tier_configs", "loyalty_points_ledger", "subscription_plans", "user_subscriptions"],
    "description": "Manages the loyalty tier system (points accumulation, tier upgrades), and premium subscription plans (Zipkart Plus / Pro).",
    "primary_keys": {
      "loyalty_tier_configs": "tier_id",
      "loyalty_points_ledger": "ledger_id",
      "subscription_plans": "plan_id",
      "user_subscriptions": "subscription_id"
    },
    "indexes": {
      "loyalty_points_ledger": [
        "user_id",
        "transaction_type",
        "reference_id",
        "created_at (DESC)",
        "is_expired",
        "expires_at"
      ],
      "user_subscriptions": [
        "user_id",
        "plan_id",
        "status",
        "current_period_end"
      ]
    },
    "enums": {
      "tier": ["bronze", "silver", "gold", "platinum", "vip"],
      "points_transaction_type": [
        "earned_order",
        "earned_review",
        "earned_referral",
        "earned_signup_bonus",
        "earned_survey",
        "earned_admin_credit",
        "redeemed_order_discount",
        "redeemed_free_delivery",
        "expired",
        "reversed_cancelled_order",
        "admin_debit"
      ],
      "subscription_status": ["trialing", "active", "past_due", "cancelled", "expired", "paused"],
      "subscription_plan_interval": ["monthly", "quarterly", "half_yearly", "annual"],
      "benefit_type": ["free_delivery", "cashback_pct", "priority_support", "early_flash_sale_access", "exclusive_coupons", "no_surge_fee"]
    },
    "constraints": [
      "points cannot go negative (floor at 0)",
      "tier downgrades happen at the end of assessment period, not immediately",
      "Only one active subscription per user at a time"
    ]
  },

