{
  "_schema_meta": {
    "primary_tables": ["promotions", "banners", "homepage_sections", "promotional_slots", "sponsored_products"],
    "description": "Manages all marketing surfaces — homepage banners, category banners, promotional campaigns that tie flash sales and coupons, sponsored product placements, and in-app interstitials.",
    "primary_keys": {
      "promotions": "promotion_id",
      "banners": "banner_id",
      "homepage_sections": "section_id",
      "promotional_slots": "slot_id",
      "sponsored_products": "sponsorship_id"
    },
    "indexes": {
      "banners": ["status", "placement", "start_at", "end_at", "priority", "composite: (placement, status, priority)"],
      "homepage_sections": ["status", "display_order"],
      "promotional_slots": ["dark_store_id", "is_active", "slot_type"],
      "sponsored_products": ["product_id", "is_active", "start_at", "end_at"]
    },
    "enums": {
      "banner_status": ["draft", "scheduled", "active", "paused", "expired", "archived"],
      "banner_placement": [
        "homepage_hero",
        "homepage_mid",
        "category_top",
        "search_top",
        "cart_page",
        "order_confirmation",
        "post_delivery",
        "checkout_upsell",
        "app_launch_interstitial",
        "story_format"
      ],
      "promotion_type": ["sale_event", "brand_day", "festival_campaign", "category_offer", "new_user_offer", "referral_campaign"],
      "click_action": ["open_url", "open_category", "open_product", "open_flash_sale", "open_coupon", "open_collection", "open_brand_page", "open_external_url"],
      "section_type": ["banner_carousel", "product_grid", "category_strip", "brand_strip", "flash_sale_timer", "recently_ordered", "trending_now", "sponsored"]
    },
    "constraints": [
      "start_at < end_at",
      "priority >= 1",
      "Only one active hero banner per placement at a time (enforced via DB unique partial index)"
    ]
  },

